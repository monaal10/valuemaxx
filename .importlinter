[importlinter]
root_packages =
    valuemaxx.core
    valuemaxx.capabilities
    valuemaxx.capture
    valuemaxx.outcomes
    valuemaxx.attribution
    valuemaxx.reconciliation
    valuemaxx.allocation
    valuemaxx.metrics
    valuemaxx.eval
    valuemaxx.onboarding
    valuemaxx.store
include_external_packages = True

# Contract 1: dependencies flow toward core. Logic packages never import each other;
# they share only via valuemaxx.core ABCs/Protocols. (AGENTS.md §3, conformance: dependency_direction)
[importlinter:contract:logic-packages-are-independent]
name = Logic packages must not import each other
type = independence
modules =
    valuemaxx.capture
    valuemaxx.outcomes
    valuemaxx.attribution
    valuemaxx.reconciliation
    valuemaxx.allocation
    valuemaxx.metrics
    valuemaxx.eval
    valuemaxx.onboarding
    valuemaxx.store

# Contract 2: logic packages must not import the surface frameworks.
# (conformance: no_logic_to_surface_import)
[importlinter:contract:logic-not-surface]
name = Logic packages must not import HTTP/MCP/CLI frameworks
type = forbidden
source_modules =
    valuemaxx.capture
    valuemaxx.outcomes
    valuemaxx.attribution
    valuemaxx.reconciliation
    valuemaxx.allocation
    valuemaxx.metrics
    valuemaxx.eval
    valuemaxx.onboarding
    valuemaxx.store
forbidden_modules =
    fastapi
    typer
    mcp

# Contract 3: capabilities is a thin registry — imports no logic package.
[importlinter:contract:capabilities-is-thin]
name = valuemaxx.capabilities imports no logic package
type = forbidden
source_modules =
    valuemaxx.capabilities
forbidden_modules =
    valuemaxx.capture
    valuemaxx.outcomes
    valuemaxx.attribution
    valuemaxx.reconciliation
    valuemaxx.allocation
    valuemaxx.metrics
    valuemaxx.eval
    valuemaxx.onboarding
    valuemaxx.store
